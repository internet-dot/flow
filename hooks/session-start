#!/usr/bin/env bash
# SessionStart hook for Flow plugin
# Injects Flow context into agent conversations at startup
# Supports: Claude Code, Codex CLI, Cursor IDE

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Build session context with auto-trigger rules and spec dir override
session_context="You have the Flow framework installed.

Flow provides Context-Driven Development with spec-first planning, TDD workflow, and Beads integration for cross-session memory.

Flow is installed and MUST be used for all development work in projects with a .agents/ directory.

AUTO-TRIGGER RULES:
- When .agents/ directory exists: ALWAYS invoke the 'flow' skill at session start
- When user asks to set up, plan, draft a PRD, design, research, document, implement, sync, check status, refresh, validate, revise, review, finish, archive, revert, or create a task: run the matching Flow workflow
- When editing files in .agents/specs/: invoke 'flow' skill for context
- When user mentions \"beads\", \"br ready\", \"br status\": invoke 'flow' skill

In Codex, plugin-defined /flow:* slash commands are not currently available. Use the installed Flow skill through natural-language requests instead, for example:
- \"Use Flow to set up this project\"
- \"Use Flow to create a PRD for add user authentication\"
- \"Use Flow to implement auth\"

When using superpowers brainstorming or writing specs/designs, you MUST write all spec files to .agents/specs/ and NEVER to docs/superpowers/specs/. This is a HARD REQUIREMENT for project organization.

MANDATORY SUPERPOWERS INTEGRATION:
- All implementation plans MUST be written to .agents/specs/<flow_id>/spec.md.
- When implement is requested, you MUST recommend "Subagent-Driven" approach if superpowers:subagent-driven-development is available.
- PRDs and Plans MUST undergo a "Self-Review" using code-reviewer or similar quality gate skills before finalization.
- TDD and Verification before completion are REQUIRED for all implementation tasks.

Use the Skill tool to invoke Flow skills. Key skills:
- flow: Main workflow orchestrator
- Other domain skills available in skills/ directory

For full details, invoke the 'flow' skill."

session_context_escaped=$(escape_for_json "$session_context")

# Output context injection as JSON based on detected platform
if [ -n "${CODEX_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context_escaped"
elif [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context_escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context_escaped"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context_escaped"
fi

exit 0
