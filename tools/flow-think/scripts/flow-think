#!/usr/bin/env bash
# flow-think - Universal launcher for flow-think-mcp
# Tries Bun first (faster), falls back to Node.js

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
ENTRY_POINT="$PROJECT_ROOT/dist/index.js"

# Check if entry point exists
if [[ ! -f "$ENTRY_POINT" ]]; then
    echo "Error: $ENTRY_POINT not found" >&2
    echo "Run 'npm run build' or 'bun run build' first" >&2
    exit 1
fi

# Try Bun first (preferred runtime)
if command -v bun &> /dev/null; then
    exec bun "$ENTRY_POINT" "$@"
fi

# Fall back to Node.js
if command -v node &> /dev/null; then
    exec node "$ENTRY_POINT" "$@"
fi

# Neither runtime available
echo "Error: Neither Bun nor Node.js found in PATH" >&2
echo "Install Bun (https://bun.sh) or Node.js (https://nodejs.org)" >&2
exit 1
