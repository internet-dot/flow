{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/AGENTS.md"],
  "agent": {
    "flow": {
      "description": "Context-driven development with Beads integration",
      "mode": "subagent"
    }
  },
  "command": {
    "flow:setup": {
      "description": "Initialize project with Flow framework",
      "agent": "flow"
    },
    "flow:prd": {
      "description": "Create new flow with spec and plan",
      "agent": "flow"
    },
    "flow:plan": {
      "description": "Create spec and plan for single flow",
      "agent": "flow"
    },
    "flow:implement": {
      "description": "Execute tasks from flow plan",
      "agent": "flow"
    },
    "flow:status": {
      "description": "Display progress overview",
      "agent": "flow"
    },
    "flow:block": {
      "description": "Mark task as blocked",
      "agent": "flow"
    },
    "flow:skip": {
      "description": "Skip task with justification",
      "agent": "flow"
    },
    "flow:archive": {
      "description": "Archive completed flow",
      "agent": "flow"
    },
    "flow:handoff": {
      "description": "Create session handoff document",
      "agent": "flow"
    },
    "flow:refresh": {
      "description": "Sync context with codebase",
      "agent": "flow"
    },
    "flow:validate": {
      "description": "Validate project integrity",
      "agent": "flow"
    },
    "flow:revert": {
      "description": "Git-aware revert",
      "agent": "flow"
    },
    "flow:research": {
      "description": "Conduct pre-PRD research",
      "agent": "flow"
    },
    "flow:revise": {
      "description": "Update spec/plan when implementation reveals issues",
      "agent": "flow"
    },
    "flow:export": {
      "description": "Generate project summary export",
      "agent": "flow"
    },
    "flow:distill": {
      "description": "Extract reusable template from completed flow",
      "agent": "flow"
    },
    "flow:formula": {
      "description": "List and manage flow templates",
      "agent": "flow"
    },
    "flow:wisp": {
      "description": "Create ephemeral exploration flow",
      "agent": "flow"
    }
  }
}
